---
import Layout from '../layouts/Layout.astro';
import HeroPage from '../components/HeroPage.astro';
import Bio from '../components/Bio.astro';

const breadcrumb = [
    { label: 'Inicio', href: '/' },
    { label: 'Bio',    href: '/bio' },
];
---

<Layout title="Bio — LU.ROMERO">
    <HeroPage
        title="BIO"
        subtitle="— Sobre Luciana Romero, MUA & Hair Artist"
        breadcrumb={breadcrumb}
    />
    <Bio />
</Layout>
