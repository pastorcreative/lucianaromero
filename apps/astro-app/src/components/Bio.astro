---
import bioImg from '../assets/img/bento/lu-romero-bio.avif';

const paragraphs = [
    'Luciana Romero nació en Argentina. Estuvo durante su infancia y adolescencia formando parte de talleres de dibujo y pintura donde fue creando su pequeño universo de texturas, detalles, formas, líneas y colores.',
    'El maquillaje y el peinado llegan a su vida por casualidad y logran atraparla por completo. Desde aquel momento y con 16 años de carrera que le anteceden, logró el perfecto engranaje de dos piezas fundamentales, la pasión y el trabajo.',
    'Luciana se destaca por su intervención artística en las más importantes revistas de moda, publicidades, desfiles, campañas gráficas, novias y eventos sociales.',
    'Creativa, innovadora, detallista, apasionada y talentosa, Luciana Romero se convirtió rápidamente en una referente del maquillaje y el peinado.',
    'Actualmente reside en Barcelona, España, desde donde expande su arte al mundo entero.',
];
---

<section class="relative z-10 bg-canvas border-t-4 border-ink px-6 md:px-12 py-16 md:py-24 transition-colors duration-300">

    <!-- Section label -->
    <div class="flex items-baseline justify-between border-b-4 border-ink pb-4 mb-12 md:mb-16 transition-colors duration-300">
        <h2 class="font-boldonse uppercase text-5xl md:text-6xl tracking-tight text-ink">BIO</h2>
        <span class="font-boldonse uppercase text-sm tracking-widest opacity-40 text-ink">— SOBRE MÍ</span>
    </div>

    <!-- Main layout -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-0 md:gap-4">

        <!-- Text column -->
        <div class="md:col-span-7 border-2 border-ink p-8 md:p-12 bg-canvas bio-card transition-colors duration-300">
            <div class="space-y-6">
                {paragraphs.map((p, i) => (
                    <p class:list={[
                        'font-aleo leading-relaxed text-ink',
                        i === 0 ? 'text-xl md:text-2xl font-medium italic' : 'text-base md:text-lg font-normal',
                    ]}>
                        {p}
                    </p>
                ))}
            </div>

            <!-- Bottom tag -->
            <div class="mt-12 pt-6 border-t-2 border-ink flex items-center justify-between transition-colors duration-300">
                <span class="font-boldonse uppercase text-xs tracking-[0.3em] opacity-40 text-ink">— MUA & HAIR</span>
                <span class="font-boldonse uppercase text-xs tracking-[0.3em] opacity-40 text-ink">BCN / ARG →</span>
            </div>
        </div>

        <!-- Image column -->
        <div class="md:col-span-5 relative mt-4 md:mt-0">
            <!-- Offset frame (neobrutalista) -->
            <div class="relative border-2 border-ink bio-img-wrapper transition-colors duration-300">
                <img
                    src={bioImg.src}
                    alt="Luciana Romero"
                    width={bioImg.width}
                    height={bioImg.height}
                    class="block w-full h-full object-cover object-top"
                    loading="lazy"
                />
                <!-- Decorative label strip -->
                <div class="absolute bottom-0 left-0 right-0 bg-ink px-4 py-2 flex items-center justify-between transition-colors duration-300">
                    <span class="font-boldonse uppercase text-canvas text-xs tracking-[0.25em]">LUCIANA ROMERO</span>
                    <span class="font-boldonse uppercase text-canvas text-xs opacity-50">©</span>
                </div>
            </div>
            <!-- Shadow block neobrutalista -->
            <div class="absolute inset-0 bg-ink -z-10 translate-x-3 translate-y-3 md:translate-x-4 md:translate-y-4 transition-colors duration-300" />
        </div>

    </div>
</section>

<style>
    .bio-card {
        box-shadow: 4px 4px 0px 0px var(--color-ink);
    }

    .bio-img-wrapper {
        aspect-ratio: 3 / 4;
        overflow: hidden;
    }

    @media (min-width: 768px) {
        .bio-img-wrapper {
            height: 100%;
            aspect-ratio: unset;
        }
    }
</style>
