---
import editorial from '../assets/img/bento/editorial-2.jpg';
import novias from '../assets/img/bento/novias-1.jpg';
import commercial from '../assets/img/bento/commercial.jpg';
import courses from '../assets/img/bento/courses.jpg';

const items = [
    {
        id: 'gallery',
        label: 'GALLERY',
        tag: '01',
        desc: 'Editoriales & retratos',
        href: '/gallery',
        inverted: false,
        spanClass: 'col-span-1 md:col-span-2 lg:col-span-2',
        arrow: true,
        image: editorial,
        imgRotate: 'rotate-2',
        imgAnchor: 'bottom-img--right bottom-img--gallery',
    },
    {
        id: 'novias',
        label: 'NOVIAS',
        tag: '02',
        desc: 'Maquillaje nupcial',
        href: '/novias',
        inverted: true,
        spanClass: 'col-span-1 md:col-span-1 lg:col-span-1 md:row-span-2 lg:row-span-2',
        arrow: true,
        image: novias,
        imgRotate: '-rotate-2',
        imgAnchor: 'bottom-img--center',
    },
    {
        id: 'commercial',
        label: 'COMMERCIAL',
        tag: '03',
        desc: 'Campañas & marcas',
        href: '/commercial',
        inverted: true,
        spanClass: 'col-span-1 md:col-span-1 lg:col-span-1',
        arrow: false,
        image: commercial,
        imgRotate: 'rotate-1',
        imgAnchor: 'bottom-img--right',
    },
    {
        id: 'courses',
        label: 'COURSES',
        tag: '04',
        desc: 'Formación profesional',
        href: '/courses',
        inverted: false,
        spanClass: 'col-span-1 md:col-span-1 lg:col-span-1',
        arrow: false,
        image: courses,
        imgRotate: '-rotate-1',
        imgAnchor: 'bottom-img--left',
    },
];
---

<section class="relative z-10 bg-canvas py-16 transition-colors duration-300">

    <div class="container-site">

    <!-- Section header -->
    <div class="flex items-baseline justify-between mb-8 border-b-4 border-ink pb-4 transition-colors duration-300">
        <h2 class="font-boldonse uppercase text-5xl md:text-6xl tracking-tight text-ink">WORK</h2>
        <span class="font-boldonse uppercase text-sm tracking-widest opacity-40 text-ink">— SELECCIÓN</span>
    </div>

    <!-- Bento grid: 1 col mobile → 2 col md → 3 col lg -->
    <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-3 auto-rows-[320px] md:auto-rows-[300px] lg:auto-rows-[360px] gap-4">
        {items.map(item => (
            <a
                href={item.href}
                class:list={[
                    'bento-cell group relative flex flex-col justify-between p-6 md:p-8 border-2 border-ink overflow-hidden cursor-pointer select-none',
                    item.spanClass,
                    item.inverted ? 'bg-ink text-canvas' : 'bg-canvas text-ink',
                ]}
            >
                <!-- Tag number -->
                <div class:list={[
                    'relative z-10 font-boldonse text-xs tracking-[0.3em] opacity-50',
                    item.inverted ? 'text-canvas' : 'text-ink',
                ]}>
                    {item.tag}
                </div>

                <!-- Image: visible always on mobile, reveal on hover on desktop -->
                <div class:list={[
                    'bento-img absolute border-2 border-ink',
                    item.imgAnchor,
                    item.imgRotate,
                ]}>
                    <img
                        src={item.image.src}
                        alt={item.label}
                        width={item.image.width}
                        height={item.image.height}
                        class="block w-full h-full object-cover"
                        loading="lazy"
                    />
                </div>

                <!-- Bottom content -->
                <div class="relative z-10 flex items-end justify-between gap-4">
                    <div>
                        <p class:list={[
                            'text-xs uppercase tracking-widest mb-2 opacity-60',
                            item.inverted ? 'text-canvas' : 'text-ink',
                        ]}>
                            {item.desc}
                        </p>
                        <h3 class:list={[
                            'font-boldonse uppercase leading-none',
                            item.id === 'gallery' ? 'text-5xl md:text-6xl lg:text-7xl' : 'text-4xl md:text-4xl lg:text-5xl',
                            item.inverted ? 'text-canvas' : 'text-ink',
                        ]}>
                            {item.label}
                        </h3>
                    </div>

                    <!-- Arrow -->
                    {item.arrow && (
                        <span class:list={[
                            'flex-shrink-0 font-boldonse text-3xl md:text-4xl transition-transform duration-200 group-hover:translate-x-1 group-hover:-translate-y-1',
                            item.inverted ? 'text-canvas' : 'text-ink',
                        ]}>
                            →
                        </span>
                    )}

                    <!-- Corner mark -->
                    {!item.arrow && (
                        <span class:list={[
                            'flex-shrink-0 font-boldonse text-2xl md:text-3xl transition-transform duration-200 group-hover:translate-x-1 group-hover:-translate-y-1',
                            item.inverted ? 'text-canvas' : 'text-ink',
                        ]}>
                            ↗
                        </span>
                    )}
                </div>

                <!-- Press overlay -->
                <div class:list={[
                    'absolute inset-0 z-20 opacity-0 group-hover:opacity-5 transition-opacity duration-150',
                    item.inverted ? 'bg-canvas' : 'bg-ink',
                ]} />
            </a>
        ))}
    </div>

    </div>

</section>

<style>
    /* ── Bento cell ── */
    .bento-cell {
        box-shadow: 4px 4px 0px 0px var(--color-ink);
        transition: box-shadow 0.15s ease, transform 0.15s ease;
    }
    .bento-cell:hover {
        box-shadow: 2px 2px 0px 0px var(--color-ink);
        transform: translate(2px, 2px);
    }
    .bento-cell:active {
        box-shadow: 0px 0px 0px 0px var(--color-ink);
        transform: translate(4px, 4px);
    }

    /* ── Image base: neobrutalista offset ── */
    .bento-img {
        width: 55%;
        aspect-ratio: 3 / 4;
        z-index: 1;
        transition: opacity 0.3s ease, transform 0.3s ease;
    }

    /* Anchors */
    .bottom-img--right {
        bottom: -12px;
        right: -12px;
    }
    .bottom-img--gallery {
        width: 32%;
        bottom: -28px;
        right: -8px;
    }
    .bottom-img--left {
        bottom: -12px;
        left: -12px;
    }
    .bottom-img--center {
        bottom: -12px;
        right: 10%;
    }

    /* Mobile: always visible */
    .bento-img {
        opacity: 1;
        transform: none;
    }

    /* Desktop: hidden until hover */
    @media (min-width: 768px) {
        .bottom-img--right  { transform: translate(8px, 24px) rotate(2deg);  opacity: 0; }
        .bottom-img--gallery { transform: translate(8px, 36px) rotate(2deg); opacity: 0; }
        .bottom-img--left   { transform: translate(-8px, 24px) rotate(-1deg); opacity: 0; }
        .bottom-img--center { transform: translate(0px, 24px) rotate(-2deg); opacity: 0; }

        .bento-cell:hover .bottom-img--right  { transform: translate(-4px, 4px) rotate(2deg);  opacity: 1; }
        .bento-cell:hover .bottom-img--gallery { transform: translate(-4px, 12px) rotate(2deg); opacity: 1; }
        .bento-cell:hover .bottom-img--left   { transform: translate(4px, 4px) rotate(-1deg); opacity: 1; }
        .bento-cell:hover .bottom-img--center { transform: translate(0px, 4px) rotate(-2deg); opacity: 1; }
    }
</style>
