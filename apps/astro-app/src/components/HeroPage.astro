---
import Breadcrumb from './Breadcrumb.astro';
import type { BreadcrumbItem } from './Breadcrumb.astro';

interface Props {
    title: string;
    subtitle?: string;
    breadcrumb: BreadcrumbItem[];
}

const { title, subtitle, breadcrumb } = Astro.props;
---

<section class="relative z-10 bg-[#f0f0f0] dark:bg-[#1c1c1c] border-b-4 border-ink pt-32 pb-16 md:pt-40 md:pb-20 px-6 md:px-12 transition-colors duration-300">

    <!-- Breadcrumb -->
    <div class="mb-10">
        <Breadcrumb items={breadcrumb} />
    </div>

    <!-- Title block -->
    <div class="border-l-4 border-ink pl-6 md:pl-10">
        <h1 class="font-boldonse uppercase text-6xl md:text-8xl lg:text-9xl tracking-tight text-ink leading-none">
            {title}
        </h1>
        {subtitle && (
            <p class="font-boldonse uppercase text-sm tracking-[0.3em] opacity-40 text-ink mt-5">
                {subtitle}
            </p>
        )}
    </div>

    <!-- Bottom rule -->
    <div class="mt-10 border-t-2 border-ink opacity-20" />

</section>
